# === Required ===
# Google AI (for Gemini Deep Research + Image Generation)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# OpenRouter (for script generation via Claude/Gemini)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# === TTS (pick one or more) ===
# Fish Audio (primary TTS)
# Get from: https://fish.audio/app/api-keys/
FISH_API_KEY=your_fish_audio_key

# Fish Audio voice ID (created after cloning your voice)
FISH_VOICE_ID=

# === Optional ===
# Pexels (free stock footage for B-roll)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key

# Supadata API Key (for reliable YouTube transcript fetching)
# Get free key from: https://supadata.ai
SUPADATA_API_KEY=your_supadata_api_key

# Default LLM model for scriptwriting
DEFAULT_MODEL=anthropic/claude-sonnet-4

# Google Sheets ID (the long string in the sheet URL)
GOOGLE_SHEET_ID=your_sheet_id

# === Pacing & Rendering Settings ===
# Number of parallel rendering threads for FFmpeg assembly (default: 20)
RENDER_MAX_WORKERS=20

# Toggle to download and analyze video reference clips (default: false)
USE_REFERENCE_CLIPS=false
REFERENCE_CLIP_DURATION=60

# Delay in seconds before subtitles start appearing (default: 60.0)
SUBTITLE_DELAY=60.0

# === Google Flow Image Generation ===
# Use Google Flow instead of Gemini API for scene images.
# Set to "flow" to use Flow, or "gemini" (default) for the existing Gemini API.
# IMAGE_SOURCE=gemini

# --- Option A: whisk-api (Recommended) ---
# Direct API client, no Chrome extension needed.
# Install: npm i -g @rohitaryal/whisk-api
# Get cookie: Open labs.google/fx/tools/whisk → Cookie Editor extension → Export Header String
# WHISK_COOKIE=your_google_cookie_here

# --- Option B: flow-agent (Fallback) ---
# Requires Chrome extension + local machine running.
# Setup: https://github.com/kodelyx/flow-agent
# FLOW_AGENT_URL=https://your-ngrok-url.ngrok.io

# Image aspect ratio for Flow generations (default: landscape)
# Options: landscape, portrait, square
# FLOW_IMAGE_ASPECT=landscape

# Delay between Flow API requests in seconds (default: 3.0)
# FLOW_REQUEST_DELAY=3.0

